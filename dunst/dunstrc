[global]
    width = 300
    height = 200
    origin = top-right
    offset = 10x10
    font = monospace 10
    format = "%s\n%b"

[urgency_low]
    background = "#000000"
    foreground = "#ffffff"
    timeout = 4

[urgency_normal]
    background = "#000000"
    foreground = "#ffffff"
    timeout = 6

[urgency_critical]
    background = "#000000"
    foreground = "#ffffff"
    timeout = 0
